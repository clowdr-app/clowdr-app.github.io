{"componentChunkName":"component---src-templates-resource-page-tsx","path":"/resources/requirements","result":{"data":{"site":{"siteMetadata":{"title":null}},"markdownRemark":{"id":"1e4aadd5-5ea3-58ab-a44f-5a3aace7a768","excerpt":"Getting Ready to Use Clowdr? We want to make sure that all users have a great experience on Clowdr! Here is the brief list of minimum technical requirements for…","htmlAst":{"type":"root","children":[{"type":"element","tagName":"h3","properties":{},"children":[{"type":"text","value":"Getting Ready to Use Clowdr?"}]},{"type":"text","value":"\n"},{"type":"element","tagName":"p","properties":{},"children":[{"type":"text","value":"We want to make sure that all users have a great experience on Clowdr!"}]},{"type":"text","value":"\n"},{"type":"element","tagName":"p","properties":{},"children":[{"type":"text","value":"Here is the brief list of minimum technical requirements for using our platform:"}]},{"type":"text","value":"\n"},{"type":"element","tagName":"ul","properties":{},"children":[{"type":"text","value":"\n"},{"type":"element","tagName":"li","properties":{},"children":[{"type":"text","value":"Highly recommended to have a stable connection of at least 5Mbps (the same as YouTube recommends for 1080p)"}]},{"type":"text","value":"\n"},{"type":"element","tagName":"li","properties":{},"children":[{"type":"text","value":"Newest version of "},{"type":"element","tagName":"a","properties":{"href":"https://www.bing.com/aclk?ld=e8nrVhoguVZwYZ2gA-FTA7YzVUCUwzEPscD5pA1AHjQJdMukkEd6SmZQ22O4tDUzrZSPcIq8ONMj5OyECe3oAmC1zBqkJL2onam3zijpD7LgUMj4yPB4H11H4llZPv2LcoqY_dkKiA2OdLs-4eAnv_1AvgCHe3faG31liNmSBJUzIAxZ0HuUn_7-zIkZFWAgJIyt_7IA&&rlid=5d556ce62c17181ec7360c6117e3c573"},"children":[{"type":"text","value":"Google Chrome"}]},{"type":"text","value":","},{"type":"element","tagName":"a","properties":{"href":""},"children":[{"type":"text","value":" Firefox"}]},{"type":"text","value":", "},{"type":"element","tagName":"a","properties":{"href":"https://www.microsoft.com/edge"},"children":[{"type":"text","value":"Edge "}]},{"type":"text","value":"or"},{"type":"element","tagName":"a","properties":{"href":""},"children":[{"type":"text","value":" Safari"}]}]},{"type":"text","value":"\n"},{"type":"element","tagName":"li","properties":{},"children":[{"type":"text","value":"Windows 10 or latest macOS"}]},{"type":"text","value":"\n"}]},{"type":"text","value":"\n"},{"type":"element","tagName":"h4","properties":{},"children":[{"type":"text","value":"Requirements for Uploads"}]},{"type":"text","value":"\n"},{"type":"element","tagName":"p","properties":{},"children":[{"type":"element","tagName":"strong","properties":{},"children":[{"type":"text","value":"Video"}]}]},{"type":"text","value":"\n"},{"type":"element","tagName":"p","properties":{},"children":[{"type":"text","value":"Clowdr supports a wide range of video upload formats. However, for the best results, we recommend that you upload videos in the following format:"}]},{"type":"text","value":"\n"},{"type":"element","tagName":"ul","properties":{},"children":[{"type":"text","value":"\n"},{"type":"element","tagName":"li","properties":{},"children":[{"type":"text","value":"Codec: H.264 (AVC)"}]},{"type":"text","value":"\n"},{"type":"element","tagName":"li","properties":{},"children":[{"type":"text","value":"Container: MP4"}]},{"type":"text","value":"\n"},{"type":"element","tagName":"li","properties":{},"children":[{"type":"text","value":"Resolution: 1920x1080 (1080p)"}]},{"type":"text","value":"\n"}]},{"type":"text","value":"\n"},{"type":"element","tagName":"p","properties":{},"children":[{"type":"text","value":"Note: Clowdr does not support the following H.264 profiles: High 4:2:2, High 10-bit, High 4:4:4. Files produced in a ‘lossless’ mode are unlikely to work."}]},{"type":"text","value":"\n"},{"type":"element","tagName":"p","properties":{},"children":[{"type":"text","value":"Tip: you can use the following "},{"type":"element","tagName":"a","properties":{"href":"https://www.ffmpeg.org/"},"children":[{"type":"text","value":"ffmpeg"}]},{"type":"text","value":" command to convert many input videos to a format Clowdr accepts."}]},{"type":"text","value":"\n"},{"type":"element","tagName":"div","properties":{"className":["gatsby-highlight"],"dataLanguage":"text"},"children":[{"type":"element","tagName":"pre","properties":{"className":["language-text"]},"children":[{"type":"element","tagName":"code","properties":{"className":["language-text"]},"children":[{"type":"text","value":"ffmpeg -i <input file> -vcodec h264 -s hd1080 -crf 23 output.mp4"}]}]}]},{"type":"text","value":"\n"},{"type":"element","tagName":"p","properties":{},"children":[{"type":"element","tagName":"strong","properties":{},"children":[{"type":"text","value":"Other Content Formats"}]}]},{"type":"text","value":"\n"},{"type":"element","tagName":"p","properties":{},"children":[{"type":"text","value":"Clowdr supports PDFs, and the following image formats: PNG, JPG/JPEG, GIF and WebP."}]},{"type":"text","value":"\n"},{"type":"element","tagName":"p","properties":{},"children":[{"type":"text","value":"We also support uploads for text/abstracts; links; youtube and other sites video embeddings (by url to the video); and zoom links!"}]},{"type":"text","value":"\n"},{"type":"element","tagName":"p","properties":{},"children":[{"type":"element","tagName":"strong","properties":{},"children":[{"type":"text","value":"Tip:"}]},{"type":"text","value":" We also highly recommend attendees use headphones and an external camera, when available. This ensures a more comfortable experience during those long networking hours!"}]}],"data":{"quirksMode":false}},"frontmatter":{"title":"Technical requirements for using Clowdr","updatedDate":"April 26, 2021","description":"Review the minimum technical requirements for using Clowdr"}}},"pageContext":{"id":"1e4aadd5-5ea3-58ab-a44f-5a3aace7a768","slug":"requirements"}},"staticQueryHashes":[]}